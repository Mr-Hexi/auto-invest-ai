# ─────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.pyd

# ─────────────────────────────────────────────
# Virtual Environments
# ─────────────────────────────────────────────
venv/
env/
.env/
.venv/

# ─────────────────────────────────────────────
# Environment variables — NEVER commit these
# ─────────────────────────────────────────────
.env
.env.local
.env.production
.env.development
.env.*.local
backend/.env

# ─────────────────────────────────────────────
# Django
# ─────────────────────────────────────────────
db.sqlite3
staticfiles/
media/
*.log

# ─────────────────────────────────────────────
# ML Model Files — upload manually via scp
# ─────────────────────────────────────────────
backend/predictions/**/lstm/
backend/predictions/**/xgboost/
*.h5
*.keras
*.pkl
*.joblib
*.pt
*.pth
# Keep the predictions directory structure but not weights
!backend/predictions/.gitkeep

# ─────────────────────────────────────────────
# Data files
# ─────────────────────────────────────────────
*.csv
forecast_data.json
*.parquet

# ─────────────────────────────────────────────
# SSH Keys — NEVER commit these
# ─────────────────────────────────────────────
*.pem
*.pub
*keys*
id_rsa*
id_ed25519*

# ─────────────────────────────────────────────
# Node / Frontend
# ─────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.env
frontend/.env.production
frontend/.env.development
frontend/.env.local
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─────────────────────────────────────────────
# IDE & OS
# ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ─────────────────────────────────────────────
# Conda
# ─────────────────────────────────────────────
conda-env/
.conda/

# ─────────────────────────────────────────────
