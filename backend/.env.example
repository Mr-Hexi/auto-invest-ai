# Backend — Django Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit the actual .env file

# ── Security ──────────────────────────────────
DJANGO_SECRET_KEY=your-super-secret-key-here-change-this

# Set to False in production
DJANGO_DEBUG=False

# Space-separated list: your VM IP + DuckDNS domain
DJANGO_ALLOWED_HOSTS=YOUR_VM_IP autoinvestapi.duckdns.org

# ── CORS — space-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://autoinvest.duckdns.org http://localhost:5173
